---
import AppShell from "../../components/AppShell.astro";
import ListingCard from "../../components/buyer/ListingCard.astro";
import { createMockFixture } from "../../lib/mock/fixtures";

const { listing } = createMockFixture();

// First slice ships one fixture listing. Blocked / draft / under-review listings
// are hidden from the marketplace; live and waitlist-only listings are shown.
const catalogue = [listing];
const visible = catalogue.filter(
  (item) => item.state === "live" || item.state === "waitlist_only",
);
---

<AppShell routeId="/app/home" title="Home" activeTab="home">
  <div class="space-y-4">
    <div>
      <h2 class="text-lg font-semibold text-slate-900">Tickets you can buy safely</h2>
      <p class="mt-1 text-sm text-slate-600">
        Every listing uses protected payment — your money is held until the transfer is done.
      </p>
    </div>

    {
      visible.length === 0 ? (
        <div class="rounded-xl border border-dashed border-slate-300 bg-white p-6 text-center">
          <p class="text-sm font-medium text-slate-700">No tickets available yet</p>
          <p class="mt-1 text-xs text-slate-500">Check back soon, or list one of your own.</p>
          <a
            href="/app/sell"
            class="mt-3 inline-block rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white"
          >
            Upload to Sell
          </a>
        </div>
      ) : (
        <div class="space-y-3">
          {visible.map((item) => (
            <ListingCard listing={item} />
          ))}
        </div>
      )
    }
  </div>
</AppShell>
