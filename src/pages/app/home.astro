---
import AppShell from "../../components/AppShell.astro";
import AuthActionGate from "../../components/AuthActionGate.astro";
import ListingCard from "../../components/buyer/ListingCard.astro";
import { createCurrentAuthState, getAuthActionState } from "../../lib/auth/authAdapter";
import { loadListingFlowView } from "../../lib/convex/dataAdapter";

const { listing } = await loadListingFlowView();
const authState = createCurrentAuthState();
const sellAction = getAuthActionState("sell", "/app/sell", authState, { requirePhoneVerified: true });

// First slice ships one fixture listing. Blocked / draft / under-review listings
// are hidden from the marketplace; live and waitlist-only listings are shown.
const catalogue = [listing];
const visible = catalogue.filter(
  (item) => item.state === "live" || item.state === "waitlist_only",
);
---

<AppShell routeId="/app/home" title="Home" activeTab="home">
  <div class="space-y-4">
    <div>
      <h2 class="text-lg font-semibold text-foreground">Tickets you can buy safely</h2>
      <p class="mt-1 text-sm text-muted-foreground">
        Every listing uses protected payment — your money is held until the transfer is done.
      </p>
    </div>

    <div
      id="home-empty-state"
      class={visible.length === 0 ? "rounded-xl border border-dashed border-border bg-card p-6 text-center" : "hidden rounded-xl border border-dashed border-border bg-card p-6 text-center"}
    >
      <p class="text-sm font-medium text-foreground">No tickets available yet</p>
      <p class="mt-1 text-xs text-muted-foreground">Check back soon, or list one of your own.</p>
      <AuthActionGate
        state={sellAction}
        label="Upload to Sell"
        class="mt-3 inline-block rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow-sm"
      />
    </div>

    <div id="home-listing-card" class={visible.length === 0 ? "hidden space-y-3" : "space-y-3"}>
      {visible.map((item) => (
        <ListingCard listing={item} />
      ))}
    </div>
  </div>
</AppShell>

<script>
  import { loadListingFlowView } from "../../lib/convex/dataAdapter";

  void loadListingFlowView()
    .then(({ listing }) => {
      const listingCard = document.getElementById("home-listing-card");
      const emptyState = document.getElementById("home-empty-state");
      const shouldShow = listing.state === "live" || listing.state === "waitlist_only";
      const hasRenderedCard = (listingCard?.children.length ?? 0) > 0;
      listingCard?.classList.toggle("hidden", !shouldShow || !hasRenderedCard);
      emptyState?.classList.toggle("hidden", shouldShow && hasRenderedCard);
    })
    .catch(() => {
      // Keep the static fallback state.
    });
</script>
