---
import AppShell from "../../components/AppShell.astro";
import BuyerTimeline from "../../components/buyer/BuyerTimeline.astro";
import { buyerStatusLabel } from "../../components/buyer/format";
import { createMockFixture } from "../../lib/mock/fixtures";
import type { OrderState } from "../../lib/types";

const { listing, order } = createMockFixture();

// Representative post-purchase state for this UI slice (the buyer has just paid,
// so the seller transfer is what's due next). Task 9 binds this to the live
// order state via the local state-transition helpers.
const displayState: OrderState = "transfer_pending";
const tickets = [{ order, listing, displayState }];
---

<AppShell routeId="/app/tickets" title="My Tickets" activeTab="tickets">
  {
    tickets.length === 0 ? (
      <div class="rounded-xl border border-dashed border-border bg-card p-6 text-center">
        <p class="text-sm font-medium text-foreground">No tickets yet</p>
        <p class="mt-1 text-xs text-muted-foreground">Tickets you buy with protection show up here.</p>
        <a
          href="/app/home"
          class="mt-3 inline-block rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow-sm"
        >
          Browse tickets
        </a>
      </div>
    ) : (
      <div class="space-y-4">
        {tickets.map((ticket) => (
          <article class="rounded-xl border border-border bg-card p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h2 class="text-base font-semibold text-foreground">{ticket.listing.title}</h2>
                <p class="mt-0.5 text-sm text-muted-foreground">{ticket.listing.venueOrRoute}</p>
              </div>
              <span class="shrink-0 rounded-full bg-primary px-2.5 py-1 text-xs font-semibold text-primary-foreground">
                {buyerStatusLabel(ticket.displayState)}
              </span>
            </div>

            <div id="buyer-live" class="mt-4"></div>

            <div class="mt-4">
              <BuyerTimeline
                currentState={ticket.displayState}
                transferDeadlineAt={ticket.listing.transferDeadlineAt}
                protectionDeadlineAt={ticket.listing.protectionDeadlineAt}
              />
            </div>

            <div class="mt-4 flex items-center gap-3 text-sm">
              <a
                href={`/app/orders/${ticket.order.id}`}
                class="rounded-lg bg-primary px-4 py-2 font-semibold text-primary-foreground shadow-sm"
              >
                View timeline
              </a>
              <a
                href={`/app/orders/${ticket.order.id}`}
                class="font-semibold text-muted-foreground underline"
              >
                Report issue
              </a>
            </div>
          </article>
        ))}
      </div>
    )
  }
</AppShell>

<script>
  import { mountTimelinePanel } from "../../lib/flow/timelinePanel.client";
  mountTimelinePanel("buyer-live", "buyer");
</script>
