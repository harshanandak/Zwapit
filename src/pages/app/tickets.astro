---
import AppShell from "../../components/AppShell.astro";
import BuyerTimeline from "../../components/buyer/BuyerTimeline.astro";
import { buyerStatusLabel } from "../../components/buyer/format";
import { createMockFixture } from "../../lib/mock/fixtures";
import type { OrderState } from "../../lib/types";

const { listing, order } = createMockFixture();

// Representative post-purchase state for this UI slice (the buyer has just paid,
// so the seller transfer is what's due next). Task 9 binds this to the live
// order state via the local state-transition helpers.
const displayState: OrderState = "transfer_pending";
const tickets = [{ order, listing, displayState }];
---

<AppShell routeId="/app/tickets" title="My Tickets" activeTab="tickets">
  {
    tickets.length === 0 ? (
      <div class="rounded-xl border border-dashed border-slate-300 bg-white p-6 text-center">
        <p class="text-sm font-medium text-slate-700">No tickets yet</p>
        <p class="mt-1 text-xs text-slate-500">Tickets you buy with protection show up here.</p>
        <a
          href="/app/home"
          class="mt-3 inline-block rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white"
        >
          Browse tickets
        </a>
      </div>
    ) : (
      <div class="space-y-4">
        {tickets.map((ticket) => (
          <article class="rounded-xl border border-slate-200 bg-white p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h2 class="text-base font-semibold text-slate-900">{ticket.listing.title}</h2>
                <p class="mt-0.5 text-sm text-slate-600">{ticket.listing.venueOrRoute}</p>
              </div>
              <span class="shrink-0 rounded-full bg-slate-900 px-2.5 py-1 text-xs font-semibold text-white">
                {buyerStatusLabel(ticket.displayState)}
              </span>
            </div>

            <div class="mt-4">
              <BuyerTimeline
                currentState={ticket.displayState}
                transferDeadlineAt={ticket.listing.transferDeadlineAt}
                protectionDeadlineAt={ticket.listing.protectionDeadlineAt}
              />
            </div>

            <div class="mt-4 flex items-center gap-3 text-sm">
              <a
                href={`/app/orders/${ticket.order.id}`}
                class="rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white"
              >
                View timeline
              </a>
              <a
                href={`/app/orders/${ticket.order.id}`}
                class="font-semibold text-slate-700 underline"
              >
                Report issue
              </a>
            </div>
          </article>
        ))}
      </div>
    )
  }
</AppShell>
