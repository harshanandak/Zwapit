---
import AppShell from "../../components/AppShell.astro";
---

<AppShell routeId="/app/me" title="Me" activeTab="me">
  <section class="space-y-4">
    <div>
      <h2 class="text-lg font-semibold text-foreground">Your account</h2>
      <p class="mt-1 text-sm text-muted-foreground">Sign in or verify your phone to continue the protected action.</p>
    </div>

    <div class="rounded-xl border border-border bg-card p-4">
      <p id="auth-intent-label" class="text-sm font-semibold text-foreground">Account required</p>
      <p id="auth-intent-copy" class="mt-1 text-sm text-muted-foreground">
        Complete your account step, then return to the action you started.
      </p>
      <a
        id="auth-intent-next"
        href="/app/home"
        class="mt-4 block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm"
        data-auth-intent="next"
      >
        Continue
      </a>
    </div>
  </section>
</AppShell>

<script>
  import { getConvexClient } from "../../lib/convex/client";
  import { functionRefs } from "../../lib/convex/functionRefs";

  const params = new URLSearchParams(window.location.search);
  const next = params.get("next");
  let target = "/app/home";
  if (next) {
    try {
      const normalized = new URL(next, window.location.origin);
      if (normalized.origin === window.location.origin && normalized.pathname.startsWith("/app/")) {
        target = `${normalized.pathname}${normalized.search}${normalized.hash}`;
      }
    } catch {
      target = "/app/home";
    }
  }
  const link = document.getElementById("auth-intent-next");
  const label = document.getElementById("auth-intent-label");
  const copy = document.getElementById("auth-intent-copy");
  const accountStepTarget = `${window.location.pathname}${window.location.search}${window.location.hash}`;
  const clerkPublishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY || import.meta.env.VITE_CLERK_PUBLISHABLE_KEY;
  const hasClerkKey = Boolean(clerkPublishableKey);
  const clerkScriptId = "zwapit-clerk-js";
  const clerkScriptUrl = "https://cdn.jsdelivr.net/npm/@clerk/clerk-js@latest/dist/clerk.browser.js";

  type ClerkRuntime = {
    load?: () => Promise<void>;
    openSignIn?: (options: { afterSignInUrl: string; afterSignUpUrl: string; redirectUrl: string }) => Promise<void>;
    openUserProfile?: () => Promise<void> | void;
    user?: unknown;
  };

  type PhoneRequirementStatus = "verified" | "required" | "unknown";

  function getClerk(): ClerkRuntime | null {
    return (window as Window & { Clerk?: ClerkRuntime }).Clerk ?? null;
  }

  function loadClerk(): Promise<ClerkRuntime | null> {
    if (!clerkPublishableKey) return Promise.resolve(null);
    const existingClerk = getClerk();
    if (existingClerk) return Promise.resolve(existingClerk);
    return new Promise((resolve) => {
      const existingScript = document.getElementById(clerkScriptId) as HTMLScriptElement | null;
      const script = existingScript ?? document.createElement("script");
      script.id = clerkScriptId;
      script.async = true;
      script.crossOrigin = "anonymous";
      script.dataset.clerkPublishableKey = clerkPublishableKey;
      script.src = clerkScriptUrl;

      const finish = async () => {
        const clerk = getClerk();
        try {
          await clerk?.load?.();
        } catch {
          resolve(null);
          return;
        }
        resolve(clerk ?? null);
      };

      script.addEventListener("load", () => void finish(), { once: true });
      script.addEventListener("error", () => resolve(null), { once: true });
      if (!existingScript) document.head.append(script);
    });
  }

  async function getPhoneRequirementStatus(): Promise<PhoneRequirementStatus> {
    const client = await getConvexClient();
    if (!client) return "unknown";
    try {
      await client.mutation(functionRefs.syncAppUserFromProvider, {});
      const requirement = (await client.query(functionRefs.getPhoneVerificationRequirement, {})) as
        | { status?: "verified" | "required" }
        | null;
      return requirement?.status === "verified" ? "verified" : "required";
    } catch {
      return "unknown";
    }
  }

  function keepOnAccountStep(): void {
    if (link instanceof HTMLAnchorElement) link.textContent = "Verify phone to continue";
    if (label) label.textContent = "Phone verification required";
    if (copy) {
      copy.textContent = "Verify your phone in your account, then return to the action you started.";
    }
  }

  if (link instanceof HTMLAnchorElement) {
    link.href = target;
    link.textContent = hasClerkKey ? "Sign in to continue" : "Continue demo";
    link.addEventListener("click", async (event) => {
      if (!hasClerkKey) return;
      event.preventDefault();
      const clerk = await loadClerk();
      if (clerk?.user) {
        const phoneStatus = await getPhoneRequirementStatus();
        if (phoneStatus === "verified") {
          window.location.href = target;
          return;
        }
        keepOnAccountStep();
        await clerk.openUserProfile?.();
        return;
      }
      await clerk?.openSignIn?.({
        afterSignInUrl: accountStepTarget,
        afterSignUpUrl: accountStepTarget,
        redirectUrl: accountStepTarget,
      });
    });
  }
  if (label) label.textContent = hasClerkKey ? "Account step required" : "Demo account ready";
  if (copy) {
    copy.textContent = hasClerkKey
      ? "Your requested action is saved. Complete sign-in or phone verification, then continue."
      : "The local demo account is active, so you can return to the action you started.";
  }
</script>
