---
import AppShell from "../../../components/AppShell.astro";
import PriceBreakdown from "../../../components/buyer/PriceBreakdown.astro";
import {
  formatDateTime,
  protectionLabel,
  transferModeLabel,
} from "../../../components/buyer/format";
import { createMockFixture } from "../../../lib/mock/fixtures";

export function getStaticPaths() {
  return [{ params: { listingId: "listing_bms_event_1" } }];
}

const { listing, sourceRule } = createMockFixture();
---

<AppShell routeId="/app/listings/:listingId" title="Listing Detail" activeTab="home">
  <div class="space-y-5">
    <div>
      <h2 class="text-xl font-semibold text-slate-900">{listing.title}</h2>
      <p class="mt-1 text-sm text-slate-600">{listing.venueOrRoute}</p>
      <p class="mt-0.5 text-sm text-slate-500">{formatDateTime(listing.eventOrTripStartAt)}</p>
    </div>

    <div class="flex flex-wrap gap-2 text-xs">
      <span class="rounded-full bg-emerald-50 px-2.5 py-1 font-semibold text-emerald-700">
        {transferModeLabel(listing.transferMode)}
      </span>
      <span class="rounded-full bg-sky-50 px-2.5 py-1 font-semibold text-sky-700">
        {protectionLabel(sourceRule.protectionLevel)}
      </span>
    </div>

    <section class="rounded-xl border border-slate-200 bg-white p-4">
      <h3 class="text-sm font-semibold text-slate-900">How this handoff works</h3>
      <dl class="mt-3 space-y-3 text-sm">
        <div>
          <dt class="font-medium text-slate-800">Transfer method</dt>
          <dd class="text-slate-600">
            {transferModeLabel(listing.transferMode)} — the seller transfers the original
            ticket to you through the official platform.
          </dd>
        </div>
        <div>
          <dt class="font-medium text-slate-800">Your protection</dt>
          <dd class="text-slate-600">
            {protectionLabel(sourceRule.protectionLevel)} — we hold your money until you confirm
            the transfer. Full refund if it doesn't arrive in time.
          </dd>
        </div>
      </dl>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-4">
      <h3 class="text-sm font-semibold text-slate-900">Price</h3>
      <div class="mt-3">
        <PriceBreakdown
          itemPrice={listing.listingPrice}
          platformFee={listing.platformFee}
          gstOnFee={listing.gstOnFee}
          totalPayable={listing.totalPayable}
        />
      </div>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-4 text-sm">
      <h3 class="text-sm font-semibold text-slate-900">Key dates</h3>
      <div class="mt-3 space-y-2">
        <p>
          <span class="font-medium text-slate-800">Transfer by</span>
          <span class="text-slate-600">{formatDateTime(listing.transferDeadlineAt)}</span>
        </p>
        <p>
          <span class="font-medium text-slate-800">Protected until</span>
          <span class="text-slate-600">{formatDateTime(listing.protectionDeadlineAt)}</span>
        </p>
      </div>
    </section>

    <a
      href={`/app/checkout/${listing.id}`}
      class="block rounded-xl bg-slate-900 px-4 py-3 text-center text-sm font-semibold text-white"
    >
      Buy with Protection
    </a>
  </div>
</AppShell>
