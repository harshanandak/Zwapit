---
import AppShell from "../../../components/AppShell.astro";
import StepNav from "../../../components/seller/StepNav.astro";
---

<AppShell routeId="/app/sell/upload" title="Upload to Sell" activeTab="sell">
  <StepNav current="upload" />

  <div class="space-y-5">
    <div>
      <h2 class="text-lg font-semibold text-foreground">Upload your ticket</h2>
      <p class="mt-1 text-sm text-muted-foreground">
        Add your ticket or pass and we'll detect the details for you — no long forms.
      </p>
    </div>

    <label
      class="flex cursor-pointer flex-col items-center justify-center gap-2 rounded-xl border-2 border-dashed border-border bg-card p-8 text-center"
    >
      <span class="text-2xl" aria-hidden="true">⬆️</span>
      <span class="text-sm font-semibold text-foreground">Add your ticket or pass</span>
      <span class="text-xs text-muted-foreground">PDF, screenshot, or pass file</span>
      <input type="file" name="ticket" class="sr-only" />
    </label>

    <p class="text-xs text-muted-foreground">
      We read the event, date, and seat details so you don't have to type them.
    </p>

    <a
      id="sell-continue"
      href="/app/sell/confirm"
      class="block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm"
      data-sell-continue
    >
      Continue
    </a>
    <p class="text-center text-xs text-muted-foreground">
      Mock upload for this slice — real file reading is added later.
    </p>
  </div>
</AppShell>

<script>
  import { gateProtectedActionLink } from "../../../lib/convex/dataAdapter";

  // Keep selling delayed-login: signed-out or phone-unverified sellers are routed
  // to the account/verify step before they can progress. Verified/demo users are
  // unaffected.
  const sellContinue = document.querySelector<HTMLAnchorElement>("[data-sell-continue]");
  let phoneGateResolved = false;
  sellContinue?.addEventListener("click", (event) => {
    if (!phoneGateResolved) event.preventDefault();
  });
  void gateProtectedActionLink("[data-sell-continue]").then(() => {
    phoneGateResolved = true;
  });
</script>
