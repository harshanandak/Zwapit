---
import AppShell from "../../../components/AppShell.astro";
import SellerTimeline from "../../../components/seller/SellerTimeline.astro";
import { formatInr, sellerStatusLabel } from "../../../components/seller/format";
import { createMockFixture } from "../../../lib/mock/fixtures";
import type { OrderState } from "../../../lib/types";

const { listing, order, sellerPaymentAccount } = createMockFixture();

// Representative state for the UI slice; Task 9 binds it to the live order state.
const displayState: OrderState = "transfer_pending";
const payout = listing.listingPrice;
const payoutReady = sellerPaymentAccount.status === "mock_ready";
const sellerOrders = [{ order, listing, displayState }];
---

<AppShell routeId="/app/sell/orders" title="Orders" activeTab="sell">
  <div class="space-y-4">
    <div
      class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm"
    >
      <span>
        <span class="font-semibold text-slate-900">Payout setup</span>
        <span class="block text-xs text-slate-500">Where your payouts go</span>
      </span>
      <span
        class:list={[
          "rounded-full px-2.5 py-1 text-xs font-semibold",
          payoutReady ? "bg-emerald-50 text-emerald-700" : "bg-yellow-50 text-yellow-800",
        ]}
      >
        {payoutReady ? "Ready (mock)" : "Needs setup"}
      </span>
    </div>

    {
      sellerOrders.length === 0 ? (
        <div class="rounded-xl border border-dashed border-slate-300 bg-white p-6 text-center">
          <p class="text-sm font-medium text-slate-700">No orders yet</p>
          <p class="mt-1 text-xs text-slate-500">
            When someone buys your ticket, the transfer task shows up here.
          </p>
        </div>
      ) : (
        sellerOrders.map((entry) => (
          <article class="rounded-xl border border-slate-200 bg-white p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h2 class="text-base font-semibold text-slate-900">{entry.listing.title}</h2>
                <p class="mt-0.5 text-sm text-slate-600">{entry.listing.venueOrRoute}</p>
              </div>
              <span class="shrink-0 rounded-full bg-slate-900 px-2.5 py-1 text-xs font-semibold text-white">
                {sellerStatusLabel(entry.displayState)}
              </span>
            </div>

            <div class="mt-3 flex items-center justify-between rounded-lg bg-slate-50 px-3 py-2 text-sm">
              <span class="text-slate-600">Your payout</span>
              <span class="font-semibold text-slate-900">{formatInr(payout)}</span>
            </div>

            <div class="mt-4">
              <SellerTimeline
                currentState={entry.displayState}
                transferDeadlineAt={entry.listing.transferDeadlineAt}
              />
            </div>
          </article>
        ))
      )
    }
  </div>
</AppShell>
