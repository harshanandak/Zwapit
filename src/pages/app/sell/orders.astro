---
import AppShell from "../../../components/AppShell.astro";
import SellerTimeline from "../../../components/seller/SellerTimeline.astro";
import { formatInr, sellerStatusLabel } from "../../../components/seller/format";
import { createMockFixture } from "../../../lib/mock/fixtures";
import type { OrderState } from "../../../lib/types";

const { listing, order, sellerPaymentAccount } = createMockFixture();

// Representative state for the UI slice; Task 9 binds it to the live order state.
const displayState: OrderState = "transfer_pending";
const payout = listing.listingPrice;
const payoutReady = sellerPaymentAccount.status === "mock_ready";
const sellerOrders = [{ order, listing, displayState }];
---

<AppShell routeId="/app/sell/orders" title="Orders" activeTab="sell">
  <div class="space-y-4">
    <div
      class="flex items-center justify-between rounded-xl border border-border bg-card px-4 py-3 text-sm"
    >
      <span>
        <span class="font-semibold text-foreground">Payout setup</span>
        <span class="block text-xs text-muted-foreground">Where your payouts go</span>
      </span>
      <span
        class:list={[
          "rounded-full px-2.5 py-1 text-xs font-semibold",
          payoutReady
            ? "bg-accent text-accent-foreground"
            : "bg-secondary text-secondary-foreground",
        ]}
      >
        {payoutReady ? "Ready (mock)" : "Needs setup"}
      </span>
    </div>

    {
      sellerOrders.length === 0 ? (
        <div class="rounded-xl border border-dashed border-border bg-card p-6 text-center">
          <p class="text-sm font-medium text-foreground">No orders yet</p>
          <p class="mt-1 text-xs text-muted-foreground">
            When someone buys your ticket, the transfer task shows up here.
          </p>
        </div>
      ) : (
        sellerOrders.map((entry) => (
          <article class="rounded-xl border border-border bg-card p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h2 class="text-base font-semibold text-foreground">{entry.listing.title}</h2>
                <p class="mt-0.5 text-sm text-muted-foreground">{entry.listing.venueOrRoute}</p>
              </div>
              <span class="shrink-0 rounded-full bg-primary px-2.5 py-1 text-xs font-semibold text-primary-foreground">
                {sellerStatusLabel(entry.displayState)}
              </span>
            </div>

            <div class="mt-3 flex items-center justify-between rounded-lg bg-muted px-3 py-2 text-sm">
              <span class="text-muted-foreground">Your payout</span>
              <span class="font-semibold text-foreground">{formatInr(payout)}</span>
            </div>

            <div id="seller-live" class="mt-4"></div>

            <div class="mt-4">
              <SellerTimeline
                currentState={entry.displayState}
                transferDeadlineAt={entry.listing.transferDeadlineAt}
              />
            </div>
          </article>
        ))
      )
    }
  </div>
</AppShell>

<script>
  import { mountTimelinePanel } from "../../../lib/flow/timelinePanel.client";
  mountTimelinePanel("seller-live", "seller");
</script>
