---
import AppShell from "../../../components/AppShell.astro";
import StepNav from "../../../components/seller/StepNav.astro";
import { ruleDecisionResult } from "../../../components/seller/format";
import { createMockFixture } from "../../../lib/mock/fixtures";

const { sourceRule } = createMockFixture();

// System-first rule decision for this listing (AUTO_APPROVE for the fixture).
const result = ruleDecisionResult(sourceRule.decision);

const promises = [
  "I'll transfer the ticket to the buyer before the deadline.",
  "The ticket is genuine and hasn't been used.",
  "I understand my payout is released only after the buyer confirms.",
];
---

<AppShell routeId="/app/sell/promise" title="Seller Promise" activeTab="sell">
  <StepNav current="promise" />

  <div class="space-y-5">
    <div>
      <h2 class="text-lg font-semibold text-slate-900">Your seller promise</h2>
      <p class="mt-1 text-sm text-slate-600">
        Confirm these so buyers can trust the handoff.
      </p>
    </div>

    <fieldset class="space-y-3 rounded-xl border border-slate-200 bg-white p-4">
      {
        promises.map((promise) => (
          <label class="flex items-start gap-3 text-sm text-slate-700">
            <input type="checkbox" checked class="mt-0.5" />
            <span>{promise}</span>
          </label>
        ))
      }
    </fieldset>

    <section class="rounded-xl border border-emerald-200 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-800">{result.title}</p>
      <p class="mt-1 text-xs text-emerald-700">{result.detail}</p>
    </section>

    <a
      href="/app/sell/orders"
      class="block rounded-xl bg-slate-900 px-4 py-3 text-center text-sm font-semibold text-white"
    >
      Go to Orders
    </a>
    <p class="text-center text-xs text-slate-400">
      Mock flow for this slice — agreeing publishes instantly here.
    </p>
  </div>
</AppShell>
