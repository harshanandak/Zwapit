---
import AppShell from "../../../components/AppShell.astro";
---

<AppShell routeId="/app/sell" title="Sell" activeTab="sell">
  <div class="space-y-5">
    <div>
      <h2 class="text-lg font-semibold text-foreground">Sell a ticket you can't use</h2>
      <p class="mt-1 text-sm text-muted-foreground">
        Upload it first — we detect the details, you set a price, and buyers pay with protection.
      </p>
    </div>

    <a
      href="/app/sell/upload"
      class="block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm"
    >
      Upload to Sell
    </a>

    <section class="rounded-xl border border-border bg-card p-4">
      <h3 class="text-sm font-semibold text-foreground">How selling works</h3>
      <ol class="mt-3 space-y-2 text-sm text-muted-foreground">
        <li>1. Upload your ticket or pass.</li>
        <li>2. We detect the details — no long forms.</li>
        <li>3. Set your price and see your payout.</li>
        <li>4. Make your seller promise and go live.</li>
      </ol>
    </section>

    <a
      href="/app/sell/orders"
      class="flex items-center justify-between rounded-xl border border-border bg-card px-4 py-3 text-sm"
    >
      <span>
        <span class="font-semibold text-foreground">Orders</span>
        <span class="block text-xs text-muted-foreground">Tickets people have bought from you</span>
      </span>
      <span aria-hidden="true" class="text-muted-foreground">›</span>
    </a>
  </div>
</AppShell>
