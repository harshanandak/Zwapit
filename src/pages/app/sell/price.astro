---
import AppShell from "../../../components/AppShell.astro";
import StepNav from "../../../components/seller/StepNav.astro";
import { formatInr } from "../../../components/seller/format";
import { createMockFixture } from "../../../lib/mock/fixtures";

const { listing } = createMockFixture();

// Seller receives the listing price; buyers pay the platform fee on top.
const payout = listing.listingPrice;
---

<AppShell routeId="/app/sell/price" title="Price" activeTab="sell">
  <StepNav current="price" />

  <div class="space-y-5">
    <div>
      <h2 class="text-lg font-semibold text-slate-900">Set your price</h2>
      <p class="mt-1 text-sm text-slate-600">
        You can price up to the face value of {formatInr(listing.faceValue)}.
      </p>
    </div>

    <label class="block">
      <span class="text-sm font-medium text-slate-700">Your price</span>
      <div
        class="mt-1 flex items-center rounded-xl border border-slate-300 bg-white px-3 py-2"
      >
        <span class="mr-1 text-slate-500">₹</span>
        <input
          type="number"
          name="price"
          value={listing.listingPrice}
          max={listing.faceValue}
          min="1"
          class="w-full text-base text-slate-900 outline-none"
        />
      </div>
      <span class="mt-1 block text-xs text-slate-500">
        Up to {formatInr(listing.faceValue)} (face value).
      </span>
    </label>

    <section class="rounded-xl border border-slate-200 bg-white p-4">
      <h3 class="text-sm font-semibold text-slate-900">Payout estimate</h3>
      <div class="mt-3 flex items-center justify-between text-sm">
        <span class="text-slate-600">You'll receive</span>
        <span class="text-lg font-semibold text-slate-900">{formatInr(payout)}</span>
      </div>
      <p class="mt-2 text-xs text-slate-500">
        Buyers pay a ₹10 + GST platform fee on top of your price. Your payout is released after the
        buyer confirms the transfer and the protection window closes.
      </p>
    </section>

    <a
      href="/app/sell/promise"
      class="block rounded-xl bg-slate-900 px-4 py-3 text-center text-sm font-semibold text-white"
    >
      Continue
    </a>
  </div>
</AppShell>
