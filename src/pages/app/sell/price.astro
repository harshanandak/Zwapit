---
import AppShell from "../../../components/AppShell.astro";
import StepNav from "../../../components/seller/StepNav.astro";
import { formatInr } from "../../../components/seller/format";
import { createMockFixture } from "../../../lib/mock/fixtures";

const { listing } = createMockFixture();

// Seller receives the listing price; buyers pay the platform fee on top.
const payout = listing.listingPrice;
---

<AppShell routeId="/app/sell/price" title="Price" activeTab="sell">
  <StepNav current="price" />

  <div class="space-y-5">
    <div>
      <h2 class="text-lg font-semibold text-foreground">Set your price</h2>
      <p class="mt-1 text-sm text-muted-foreground">
        You can price up to the face value of {formatInr(listing.faceValue)}.
      </p>
    </div>

    <label class="block">
      <span class="text-sm font-medium text-foreground">Your price</span>
      <div
        class="mt-1 flex items-center rounded-xl border border-border bg-card px-3 py-2"
      >
        <span class="mr-1 text-muted-foreground">₹</span>
        <input
          type="number"
          name="price"
          value={listing.listingPrice}
          max={listing.faceValue}
          min="1"
          class="w-full bg-transparent text-base text-foreground outline-none"
        />
      </div>
      <span class="mt-1 block text-xs text-muted-foreground">
        Up to {formatInr(listing.faceValue)} (face value).
      </span>
    </label>

    <section class="rounded-xl border border-border bg-card p-4">
      <h3 class="text-sm font-semibold text-foreground">Payout estimate</h3>
      <div class="mt-3 flex items-center justify-between text-sm">
        <span class="text-muted-foreground">You'll receive</span>
        <span class="text-lg font-semibold text-foreground">{formatInr(payout)}</span>
      </div>
      <p class="mt-2 text-xs text-muted-foreground">
        Buyers pay a ₹10 + GST platform fee on top of your price. Your payout is released after the
        buyer confirms the transfer and the protection window closes.
      </p>
    </section>

    <a
      id="sell-continue"
      href="/app/sell/promise"
      class="block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm"
      data-sell-continue
    >
      Continue
    </a>
  </div>
</AppShell>

<script>
  import { gateProtectedActionLink } from "../../../lib/convex/dataAdapter";

  const sellContinue = document.querySelector<HTMLAnchorElement>("[data-sell-continue]");
  let phoneGateResolved = false;
  sellContinue?.addEventListener("click", (event) => {
    if (!phoneGateResolved) event.preventDefault();
  });
  void gateProtectedActionLink("[data-sell-continue]").then(() => {
    phoneGateResolved = true;
  });
</script>
