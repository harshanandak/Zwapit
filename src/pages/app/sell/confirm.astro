---
import AppShell from "../../../components/AppShell.astro";
import StepNav from "../../../components/seller/StepNav.astro";
import {
  buildSellerDraftFromListing,
  formatDateTime,
  formatInr,
  transferModeLabel,
} from "../../../components/seller/format";
import { createMockFixture } from "../../../lib/mock/fixtures";

const { listing } = createMockFixture();
const detectedDraft = buildSellerDraftFromListing(listing);

const sourceLabels: Record<string, string> = {
  bookmyshow: "BookMyShow",
  district: "District",
  bus_operator: "Bus operator",
  other_platform: "Other platform",
  manual_upload: "Manual upload",
};
const categoryLabels: Record<string, string> = {
  event_ticket: "Event ticket",
  movie_ticket: "Movie ticket",
  bus_travel: "Bus travel",
  watcher: "Watcher",
  future_category: "Other",
};

const details = [
  { label: "Event", value: listing.title },
  { label: "Venue", value: listing.venueOrRoute },
  { label: "Date & time", value: formatDateTime(listing.eventOrTripStartAt) },
  { label: "Source", value: sourceLabels[listing.source] ?? listing.source },
  { label: "Category", value: categoryLabels[listing.category] ?? listing.category },
  { label: "Quantity", value: String(listing.quantity) },
  { label: "Face value", value: formatInr(listing.faceValue) },
  { label: "Transfer method", value: transferModeLabel(listing.transferMode) },
];
---

<AppShell routeId="/app/sell/confirm" title="Confirm Details" activeTab="sell">
  <StepNav current="confirm" />

  <div class="space-y-5">
    <div>
      <h2 class="text-lg font-semibold text-foreground">Detected details</h2>
      <p class="mt-1 text-sm text-muted-foreground">
        We detected these from your upload. Check they're right before you continue.
      </p>
    </div>

    <dl class="divide-y divide-border rounded-xl border border-border bg-card">
      {
        details.map((detail) => (
          <div class="flex items-center justify-between gap-4 px-4 py-3 text-sm">
            <dt class="text-muted-foreground">{detail.label}</dt>
            <dd class="text-right font-medium text-foreground">{detail.value}</dd>
          </div>
        ))
      }
    </dl>

    <div class="flex gap-3">
      <a
        href="/app/sell/upload"
        class="rounded-xl border border-border px-4 py-3 text-sm font-semibold text-foreground"
      >
        Edit
      </a>
      <a
        id="sell-continue"
        href="/app/sell/price"
        class="flex-1 rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm"
        data-sell-continue
      >
        Looks right
      </a>
    </div>
  </div>

  <script type="application/json" id="seller-detected-draft" is:inline set:html={JSON.stringify(detectedDraft)}
  ></script>
</AppShell>

<script>
  import { gateProtectedActionLink } from "../../../lib/convex/dataAdapter";
  import { SELLER_DRAFT_STORAGE_KEY } from "../../../components/seller/format";
  import type { SellerListingDraft } from "../../../lib/types";

  // Ensure the carried draft exists even if the seller deep-linked to Confirm.
  try {
    const node = document.getElementById("seller-detected-draft");
    if (node?.textContent && !sessionStorage.getItem(SELLER_DRAFT_STORAGE_KEY)) {
      const detected = JSON.parse(node.textContent) as SellerListingDraft;
      sessionStorage.setItem(SELLER_DRAFT_STORAGE_KEY, JSON.stringify(detected));
    }
  } catch {
    // sessionStorage unavailable — later steps fall back to the embedded draft.
  }

  const sellContinue = document.querySelector<HTMLAnchorElement>("[data-sell-continue]");
  let phoneGateResolved = false;
  sellContinue?.addEventListener("click", (event) => {
    if (!phoneGateResolved) event.preventDefault();
  });
  void gateProtectedActionLink("[data-sell-continue]").then(() => {
    phoneGateResolved = true;
  });
</script>
