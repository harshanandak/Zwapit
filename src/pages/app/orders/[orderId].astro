---
import AppShell from "../../../components/AppShell.astro";
import BuyerTimeline from "../../../components/buyer/BuyerTimeline.astro";
import PriceBreakdown from "../../../components/buyer/PriceBreakdown.astro";
import ReportIssue from "../../../components/buyer/ReportIssue.astro";
import { buyerStatusLabel } from "../../../components/buyer/format";
import { createMockFixture } from "../../../lib/mock/fixtures";
import type { OrderState } from "../../../lib/types";

export function getStaticPaths() {
  return [{ params: { orderId: "order_demo_1" } }];
}

const { listing, order } = createMockFixture();
const summary = order.mockPaymentSummary;

// Representative state for the UI slice; Task 9 binds it to the live order state.
const displayState: OrderState = "transfer_pending";
---

<AppShell routeId="/app/orders/:orderId" title="Transfer Timeline" activeTab="tickets">
  <div class="space-y-5">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h2 class="text-base font-semibold text-slate-900">{listing.title}</h2>
        <p class="mt-0.5 text-sm text-slate-600">{listing.venueOrRoute}</p>
      </div>
      <span class="shrink-0 rounded-full bg-slate-900 px-2.5 py-1 text-xs font-semibold text-white">
        {buyerStatusLabel(displayState)}
      </span>
    </div>

    <section class="rounded-xl border border-slate-200 bg-white p-4">
      <h3 class="text-sm font-semibold text-slate-900">Your timeline</h3>
      <div class="mt-3">
        <BuyerTimeline
          currentState={displayState}
          transferDeadlineAt={listing.transferDeadlineAt}
          protectionDeadlineAt={listing.protectionDeadlineAt}
        />
      </div>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-4">
      <h3 class="text-sm font-semibold text-slate-900">What you paid</h3>
      <div class="mt-3">
        <PriceBreakdown
          itemPrice={summary.itemPrice}
          platformFee={summary.platformFee}
          gstOnFee={summary.gstOnPlatformFee}
          totalPayable={summary.totalPayable}
        />
      </div>
    </section>

    <section>
      <h3 class="mb-2 text-sm font-semibold text-slate-900">Something wrong?</h3>
      <ReportIssue />
    </section>
  </div>
</AppShell>
