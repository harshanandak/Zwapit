---
import AppShell from "../../../components/AppShell.astro";
import PriceBreakdown from "../../../components/buyer/PriceBreakdown.astro";
import {
  formatDateTime,
  formatInr,
  protectionLabel,
  transferModeLabel,
} from "../../../components/buyer/format";
import { createMockFixture } from "../../../lib/mock/fixtures";

export function getStaticPaths() {
  return [{ params: { listingId: "listing_bms_event_1" } }];
}

const { listing, sourceRule } = createMockFixture();
const payLabel = `Pay ${formatInr(listing.totalPayable)}`;
---

<AppShell routeId="/app/checkout/:listingId" title="Buy with Protection" activeTab="home">
  <div class="space-y-5">
    <div>
      <h2 class="text-lg font-semibold text-foreground">{listing.title}</h2>
      <p class="mt-1 text-sm text-muted-foreground">{listing.venueOrRoute}</p>
    </div>

    <div class="flex flex-wrap gap-2 text-xs">
      <span class="rounded-full bg-primary/15 px-2.5 py-1 font-semibold text-primary">
        {transferModeLabel(listing.transferMode)}
      </span>
      <span class="rounded-full bg-accent px-2.5 py-1 font-semibold text-accent-foreground">
        {protectionLabel(sourceRule.protectionLevel)}
      </span>
    </div>

    <section class="rounded-xl border border-border bg-card p-4">
      <h3 class="text-sm font-semibold text-foreground">You pay</h3>
      <div class="mt-3">
        <PriceBreakdown
          itemPrice={listing.listingPrice}
          platformFee={listing.platformFee}
          gstOnFee={listing.gstOnFee}
          totalPayable={listing.totalPayable}
        />
      </div>
    </section>

    <section class="rounded-xl border border-border bg-card p-4 text-sm">
      <h3 class="text-sm font-semibold text-foreground">Refund conditions</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-muted-foreground">
        <li>Full refund if the seller doesn't transfer before the deadline.</li>
        <li>Full refund if the ticket doesn't match or can't be used.</li>
        <li>Your money is released to the seller only after you confirm the transfer.</li>
      </ul>
      <p class="mt-3 text-xs text-muted-foreground">
        <span class="font-medium text-foreground">Transfer by</span>
        {formatDateTime(listing.transferDeadlineAt)}
      </p>
      <p class="mt-1 text-xs text-muted-foreground">
        Checkout is blocked if the listing isn't live or the transfer deadline has passed — you
        won't be charged.
      </p>
    </section>

    <label class="flex items-start gap-3 rounded-xl border border-border bg-card p-4 text-sm text-foreground">
      <input id="eligibility-ack" type="checkbox" class="mt-0.5 accent-primary" />
      <span>I understand the ticket rules and will carry any required ID or proof.</span>
    </label>

    <a
      id="pay-button"
      href="/app/tickets"
      class="block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm"
    >
      {payLabel}
    </a>
    <p id="checkout-warning" class="text-center text-xs text-destructive"></p>
    <p class="text-center text-xs text-muted-foreground">
      Mock checkout for this slice — no real payment is taken.
    </p>
  </div>
</AppShell>

<script>
  import { createMockFixture } from "../../../lib/mock/fixtures";
  import { saveDemoState } from "../../../lib/flow/mockFlow";
  import { runMockCheckout } from "../../../lib/convex/dataAdapter";

  // Mock pay: validate checkout, transition checkout_pending -> transfer_pending,
  // persist the order (Convex when configured, local otherwise), then show it in
  // My Tickets. No real payment. The Convex write is awaited BEFORE navigating so
  // a later direct load of the order page reveals the paid timeline from Convex.
  const payButton = document.getElementById("pay-button");
  const eligibilityAck = document.getElementById("eligibility-ack") as HTMLInputElement | null;
  payButton?.addEventListener("click", (event) => {
    event.preventDefault();
    const { order, transferTask } = createMockFixture();
    // runMockCheckout runs the same local validation/mock-pay. With Convex
    // configured, a rejected persistence write surfaces as a blocker.
    void runMockCheckout(order, {
      buyerEligibilityAcknowledged: eligibilityAck?.checked === true,
    }).then((result) => {
      if (!result.ok) {
        const warning = document.getElementById("checkout-warning");
        if (warning) warning.textContent = `Checkout is blocked: ${result.blockers.join(", ")}`;
        return;
      }
      // Keep the local demo timeline working (and as the offline fallback).
      saveDemoState({ order: result.order, transferTask });
      window.location.href = "/app/tickets";
    });
  });
</script>
