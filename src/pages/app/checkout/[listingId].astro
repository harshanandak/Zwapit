---
import AppShell from "../../../components/AppShell.astro";
import PriceBreakdown from "../../../components/buyer/PriceBreakdown.astro";
import {
  formatDateTime,
  formatInr,
  protectionLabel,
  transferModeLabel,
} from "../../../components/buyer/format";
import { createCurrentAuthState, getAuthActionState } from "../../../lib/auth/authAdapter";
import { accountStepUrl, loadListingFlowView } from "../../../lib/convex/dataAdapter";

export function getStaticPaths() {
  return [{ params: { listingId: "listing_bms_event_1" } }];
}

const { listing, sourceRule, purchasable } = await loadListingFlowView();
const payLabel = `Pay ${formatInr(listing.totalPayable)}`;

// Protected checkout execution gate. The frontmatter value is a build-time
// fail-closed default; the per-user decision is refined client-side from the
// Convex identity boundary, and the mock-pay mutation itself rejects unverified
// buyers. Full price is always shown before payment regardless of gate state.
const checkoutHref = `/app/checkout/${listing.id}`;
const buyAction = getAuthActionState("buy", checkoutHref, createCurrentAuthState(), { requirePhoneVerified: true });
const buyAllowed = buyAction.status === "allowed";
const authStepHref = accountStepUrl(checkoutHref);
---

<AppShell routeId="/app/checkout/:listingId" title="Buy with Protection" activeTab="home">
  <div class="space-y-5">
    <div>
      <h2 class="text-lg font-semibold text-foreground">{listing.title}</h2>
      <p class="mt-1 text-sm text-muted-foreground">{listing.venueOrRoute}</p>
    </div>

    <div class="flex flex-wrap gap-2 text-xs">
      <span class="rounded-full bg-primary/15 px-2.5 py-1 font-semibold text-primary">
        {transferModeLabel(listing.transferMode)}
      </span>
      <span class="rounded-full bg-accent px-2.5 py-1 font-semibold text-accent-foreground">
        {protectionLabel(sourceRule.protectionLevel)}
      </span>
    </div>

    <section class="rounded-xl border border-border bg-card p-4">
      <h3 class="text-sm font-semibold text-foreground">You pay</h3>
      <div class="mt-3">
        <PriceBreakdown
          itemPrice={listing.listingPrice}
          platformFee={listing.platformFee}
          gstOnFee={listing.gstOnFee}
          totalPayable={listing.totalPayable}
        />
      </div>
    </section>

    <section class="rounded-xl border border-border bg-card p-4 text-sm">
      <h3 class="text-sm font-semibold text-foreground">Refund conditions</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-muted-foreground">
        <li>Full refund if the seller doesn't transfer before the deadline.</li>
        <li>Full refund if the ticket doesn't match or can't be used.</li>
        <li>Your money is released to the seller only after you confirm the transfer.</li>
      </ul>
      <p class="mt-3 text-xs text-muted-foreground">
        <span class="font-medium text-foreground">Transfer by</span>
        {formatDateTime(listing.transferDeadlineAt)}
      </p>
      <p class="mt-1 text-xs text-muted-foreground">
        <span class="font-medium text-foreground">Protected until</span>
        {formatDateTime(listing.protectionDeadlineAt)}
      </p>
      <p class="mt-1 text-xs text-muted-foreground">
        Checkout is blocked if the listing isn't live or the transfer deadline has passed — you
        won't be charged.
      </p>
    </section>

    <label class="flex items-start gap-3 rounded-xl border border-border bg-card p-4 text-sm text-foreground">
      <input id="eligibility-ack" type="checkbox" class="mt-0.5 accent-primary" />
      <span>I understand the ticket rules and will carry any required ID or proof.</span>
    </label>

    <a
      id="pay-button"
      href="/app/tickets"
      class={purchasable && buyAllowed ? "block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm" : "hidden rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm"}
    >
      {payLabel}
    </a>
    <div
      id="checkout-auth-gate"
      class={purchasable && !buyAllowed ? "rounded-xl border border-primary/40 bg-primary/10 p-4 text-center" : "hidden rounded-xl border border-primary/40 bg-primary/10 p-4 text-center"}
    >
      <p class="text-sm font-semibold text-foreground">Verify your phone to buy with protection</p>
      <p class="mt-1 text-xs text-muted-foreground">
        A verified phone keeps your protected payment safe. We'll bring you right back here.
      </p>
      <a
        id="checkout-auth-link"
        href={authStepHref}
        class="mt-3 block rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground shadow-sm"
        data-auth-action="buy"
        data-auth-state={buyAction.status}
      >
        {buyAction.status === "sign_in_required" ? "Sign in to continue" : "Verify phone to continue"}
      </a>
    </div>
    <p
      id="checkout-unavailable"
      class={!purchasable ? "rounded-xl border border-border bg-muted px-4 py-3 text-center text-sm font-semibold text-muted-foreground" : "hidden rounded-xl border border-border bg-muted px-4 py-3 text-center text-sm font-semibold text-muted-foreground"}
    >
      This listing is no longer available.
    </p>
    <p id="checkout-warning" class="text-center text-xs text-destructive"></p>
    <p class="text-center text-xs text-muted-foreground">
      Mock checkout for this slice — no real payment is taken.
    </p>
  </div>
</AppShell>

<script>
  import { createMockFixture } from "../../../lib/mock/fixtures";
  import { saveDemoState } from "../../../lib/flow/mockFlow";
  import {
    accountStepUrl,
    loadListingFlowView,
    resolvePhoneGateStatus,
    runMockCheckout,
  } from "../../../lib/convex/dataAdapter";

  // Mock pay: validate checkout, transition checkout_pending -> transfer_pending,
  // persist the order (Convex when configured, local otherwise), then show it in
  // My Tickets. No real payment. The Convex write is awaited BEFORE navigating so
  // a later direct load of the order page reveals the paid timeline from Convex.
  let checkoutInFlight = false;
  let phoneGated = false;
  const payButton = document.getElementById("pay-button") as HTMLAnchorElement | null;
  const authGate = document.getElementById("checkout-auth-gate");
  const authLink = document.getElementById("checkout-auth-link") as HTMLAnchorElement | null;
  const unavailable = document.getElementById("checkout-unavailable");
  const eligibilityAck = document.getElementById("eligibility-ack") as HTMLInputElement | null;
  const nextIntent = `${window.location.pathname}${window.location.search}`;

  function showUnavailable(): void {
    phoneGated = false;
    payButton?.classList.add("hidden");
    authGate?.classList.add("hidden");
    unavailable?.classList.remove("hidden");
  }

  function showAuthGate(status: "signed_out" | "required"): void {
    phoneGated = true;
    payButton?.classList.add("hidden");
    unavailable?.classList.add("hidden");
    if (authLink) {
      authLink.href = accountStepUrl(nextIntent);
      authLink.textContent = status === "signed_out" ? "Sign in to continue" : "Verify phone to continue";
      authLink.dataset.authState = status === "signed_out" ? "sign_in_required" : "phone_verification_required";
    }
    authGate?.classList.remove("hidden");
  }

  // Listing availability wins first; purchasable listings then require a
  // verified-phone state before mock checkout can execute.
  void (async () => {
    let currentPurchasable = unavailable === null || unavailable.classList.contains("hidden");
    try {
      const listingView = await loadListingFlowView();
      currentPurchasable = listingView.purchasable;
    } catch {
      // Keep the static fallback state.
    }
    if (!currentPurchasable) {
      showUnavailable();
      return;
    }

    const status = await resolvePhoneGateStatus();
    if (status !== "verified") {
      showAuthGate(status === "signed_out" ? "signed_out" : "required");
      return;
    }

    authGate?.classList.add("hidden");
    unavailable?.classList.add("hidden");
    payButton?.classList.remove("hidden");
  })();

  payButton?.addEventListener("click", async (event) => {
    event.preventDefault();
    if (phoneGated || checkoutInFlight) return;
    checkoutInFlight = true;
    payButton.setAttribute("aria-disabled", "true");
    payButton.classList.add("pointer-events-none", "opacity-70");
    const warning = document.getElementById("checkout-warning");
    if (warning) warning.textContent = "";
    const { order, transferTask } = createMockFixture();
    // runMockCheckout runs the same local validation/mock-pay. With Convex
    // configured, a rejected persistence write or identity-gate rejection
    // surfaces as a blocker.
    try {
      const result = await runMockCheckout(order, {
        buyerEligibilityAcknowledged: eligibilityAck?.checked === true,
      });
      if (!result.ok) {
        if (result.blockers.includes("PHONE_VERIFICATION_REQUIRED")) {
          showAuthGate("required");
          if (warning) warning.textContent = "Verify your phone to complete checkout.";
        } else if (result.blockers.includes("AUTH_REQUIRED")) {
          showAuthGate("signed_out");
          if (warning) warning.textContent = "Sign in to complete checkout.";
        } else if (warning) {
          warning.textContent = `Checkout is blocked: ${result.blockers.join(", ")}`;
        }
        return;
      }
      // Keep the local demo timeline working (and as the offline fallback).
      saveDemoState({ order: result.order, transferTask });
      window.location.href = "/app/tickets";
    } catch {
      if (warning) warning.textContent = "Checkout could not be completed right now. Please try again.";
    } finally {
      checkoutInFlight = false;
      payButton.removeAttribute("aria-disabled");
      payButton.classList.remove("pointer-events-none", "opacity-70");
    }
  });
</script>
