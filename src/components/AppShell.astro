---
import AppLayout from "../layouts/AppLayout.astro";
import BottomNav from "./BottomNav.astro";

interface Props {
  activeTab?: "home" | "sell" | "tickets" | "me";
  routeId: string;
  title: string;
}

const { activeTab, routeId, title } = Astro.props;
---

<AppLayout title={`${title} | Zwapit`}>
  <main data-route-id={routeId} class="mx-auto min-h-dvh max-w-md bg-background px-5 pb-28 pt-6 text-foreground">
    <header class="mb-6">
      <p class="text-xs font-semibold uppercase tracking-wide text-primary">Zwapit</p>
      <h1 class="mt-2 text-2xl font-semibold tracking-normal text-foreground">{title}</h1>
    </header>
    <div>
      <slot />
    </div>
  </main>
  <BottomNav activeTab={activeTab} />
</AppLayout>
