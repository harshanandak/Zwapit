---
interface Props {
  activeTab?: "home" | "sell" | "tickets" | "me";
}

const { activeTab } = Astro.props;

const items = [
  { label: "Home", href: "/app/home", key: "home" },
  { label: "Sell", href: "/app/sell", key: "sell" },
  { label: "My Tickets", href: "/app/tickets", key: "tickets" },
  { label: "Me", href: "/app/me", key: "me" },
] as const;
---

<nav class="fixed inset-x-0 bottom-0 z-10 border-t border-slate-200 bg-white/95 px-3 pb-3 pt-2 shadow-[0_-8px_24px_rgba(15,23,42,0.08)] backdrop-blur">
  <div class="mx-auto grid max-w-md grid-cols-4 gap-1">
    {
      items.map((item) => (
        <a
          class:list={[
            "rounded-md px-2 py-2 text-center text-sm font-medium",
            activeTab === item.key ? "bg-slate-900 text-white" : "text-slate-600",
          ]}
          href={item.href}
        >
          {item.label}
        </a>
      ))
    }
  </div>
</nav>
