---
import type { MockListing } from "../../lib/types";
import { formatDateTime, formatInr, transferModeLabel } from "./format";

interface Props {
  listing: MockListing;
}

const { listing } = Astro.props;
const isWaitlist = listing.state === "waitlist_only";
---

<article class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-base font-semibold text-slate-900">{listing.title}</h3>
      <p class="mt-0.5 text-sm text-slate-600">{listing.venueOrRoute}</p>
      <p class="mt-0.5 text-xs text-slate-500">{formatDateTime(listing.eventOrTripStartAt)}</p>
    </div>
    <span
      class="shrink-0 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700"
    >
      {transferModeLabel(listing.transferMode)}
    </span>
  </div>

  <div class="mt-3 flex flex-wrap items-center gap-2 text-xs">
    {
      isWaitlist ? (
        <span class="rounded-full bg-yellow-50 px-2.5 py-1 font-medium text-yellow-800">
          Waitlist Only
        </span>
      ) : (
        <span class="rounded-full bg-sky-50 px-2.5 py-1 font-medium text-sky-700">
          Protected payment
        </span>
      )
    }
    <span class="text-slate-500">Qty {listing.quantity}</span>
  </div>

  <div class="mt-4 flex items-center justify-between">
    <div>
      <p class="text-xs text-slate-500">Price</p>
      <p class="text-lg font-semibold text-slate-900">{formatInr(listing.listingPrice)}</p>
    </div>
    {
      isWaitlist ? (
        <span class="rounded-lg bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-500">
          Waitlist Only
        </span>
      ) : (
        <a
          href={`/app/listings/${listing.id}`}
          class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white"
        >
          Buy with Protection
        </a>
      )
    }
  </div>
</article>
