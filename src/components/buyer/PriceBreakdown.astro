---
import { formatInr } from "./format";

interface Props {
  itemPrice: number;
  platformFee: number;
  gstOnFee: number;
  totalPayable: number;
}

const { itemPrice, platformFee, gstOnFee, totalPayable } = Astro.props;
---

<dl class="space-y-2 text-sm">
  <div class="flex items-center justify-between">
    <dt class="text-slate-600">Item price</dt>
    <dd class="font-medium text-slate-900">{formatInr(itemPrice)}</dd>
  </div>
  <div class="flex items-center justify-between">
    <dt class="text-slate-600">Platform fee</dt>
    <dd class="font-medium text-slate-900">{formatInr(platformFee)}</dd>
  </div>
  <div class="flex items-center justify-between">
    <dt class="text-slate-600">GST on fee (18%)</dt>
    <dd class="font-medium text-slate-900">{formatInr(gstOnFee)}</dd>
  </div>
  <div
    class="flex items-center justify-between border-t border-slate-200 pt-2 text-base"
  >
    <dt class="font-semibold text-slate-900">Total payable</dt>
    <dd class="font-semibold text-slate-900">{formatInr(totalPayable)}</dd>
  </div>
</dl>
<p class="mt-2 text-xs text-slate-500">Platform fee is ₹10 + GST. The full price is shown before you pay.</p>
