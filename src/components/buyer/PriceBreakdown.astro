---
import { formatInr } from "./format";

interface Props {
  itemPrice: number;
  platformFee: number;
  gstOnFee: number;
  totalPayable: number;
}

const { itemPrice, platformFee, gstOnFee, totalPayable } = Astro.props;
---

<dl class="space-y-2 text-sm">
  <div class="flex items-center justify-between">
    <dt class="text-muted-foreground">Item price</dt>
    <dd class="font-medium text-foreground">{formatInr(itemPrice)}</dd>
  </div>
  <div class="flex items-center justify-between">
    <dt class="text-muted-foreground">Platform fee</dt>
    <dd class="font-medium text-foreground">{formatInr(platformFee)}</dd>
  </div>
  <div class="flex items-center justify-between">
    <dt class="text-muted-foreground">GST on fee (18%)</dt>
    <dd class="font-medium text-foreground">{formatInr(gstOnFee)}</dd>
  </div>
  <div
    class="flex items-center justify-between border-t border-border pt-2 text-base"
  >
    <dt class="font-semibold text-foreground">Total payable</dt>
    <dd class="font-semibold text-foreground">{formatInr(totalPayable)}</dd>
  </div>
</dl>
<p class="mt-2 text-xs text-muted-foreground">Platform fee is ₹10 + GST. The full price is shown before you pay.</p>
