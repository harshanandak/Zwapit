---
import type { AuthActionState } from "../lib/auth/authAdapter";

interface Props {
  class?: string;
  id?: string;
  label: string;
  state: AuthActionState;
}

const { class: className = "", id, label, state } = Astro.props;
const gateHref = `/app/me?next=${encodeURIComponent(state.href)}`;
const href = state.status === "allowed" ? state.href : gateHref;
---

<a id={id} href={href} class={className} data-auth-action={state.action} data-auth-state={state.status}>
  {label}
</a>
