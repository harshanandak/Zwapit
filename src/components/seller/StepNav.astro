---
// Upload-first step indicator for the seller flow (Task 5).
interface Props {
  current: "upload" | "confirm" | "price" | "promise";
}

const { current } = Astro.props;

const steps = [
  { key: "upload", label: "Upload" },
  { key: "confirm", label: "Confirm" },
  { key: "price", label: "Price" },
  { key: "promise", label: "Promise" },
] as const;

const currentIndex = steps.findIndex((step) => step.key === current);
---

<ol class="mb-5 flex items-center gap-2 text-xs">
  {
    steps.map((step, index) => (
      <li class="flex flex-1 items-center gap-2">
        <span
          class:list={[
            "flex h-6 w-6 shrink-0 items-center justify-center rounded-full font-semibold",
            index < currentIndex && "bg-accent text-accent-foreground",
            index === currentIndex && "bg-primary text-primary-foreground",
            index > currentIndex && "border border-border bg-card text-muted-foreground",
          ]}
        >
          {index < currentIndex ? "✓" : index + 1}
        </span>
        <span
          class:list={[
            "truncate",
            index === currentIndex ? "font-semibold text-foreground" : "text-muted-foreground",
          ]}
        >
          {step.label}
        </span>
        {index < steps.length - 1 && <span class="h-px flex-1 bg-border" />}
      </li>
    ))
  }
</ol>
