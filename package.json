{
  "name": "zwapit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "check": "astro check",
    "check:routes": "bun scripts/route-coverage.mjs",
    "cap:sync": "bun run build && cap sync",
    "cap:doctor": "cap doctor",
    "android:sync": "bun run build && cap sync android",
    "android:build:debug": "bun run android:sync && bun scripts/build-android-debug.mjs",
    "android:test:debug": "bun run android:sync && bun scripts/test-android-debug.mjs",
    "ios:sync": "bun run build && cap sync ios",
    "ios:build:sim": "bun run ios:sync && bun scripts/build-ios-simulator.mjs",
    "cf:deploy": "bun run build && wrangler deploy",
    "cf:preview": "bun run build && wrangler versions upload",
    "cf:dry-run": "bun run build && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.0",
    "@capacitor/android": "7.6.6",
    "@capacitor/core": "7.6.6",
    "@capacitor/ios": "7.6.6",
    "@fontsource/poppins": "^5.2.7",
    "@tailwindcss/postcss": "^4.1.17",
    "astro": "^6.3.1",
    "convex": "^1.39.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/ts-plugin": "^1.10.4",
    "@capacitor/cli": "7.6.6",
    "@types/bun": "latest",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.8",
    "typescript": "^5.9.3",
    "wrangler": "^4.95.0"
  },
  "overrides": {
    "ws": "8.20.1",
    "yaml-language-server": "1.23.0"
  }
}
