# Copy to .env.local and fill in your Convex dev deployment values.
# See docs/deploy/convex-local-dev.md for the canonical Zwapit dev deployment.
PUBLIC_CONVEX_URL=https://<your-deployment-name>.convex.cloud
CONVEX_DEPLOYMENT=dev:<your-deployment-name>

# Clerk public browser key. Leave unset for the local no-Clerk demo flow.
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-clerk-publishable-key>

# Legacy/Vite compatibility fallback. Prefer PUBLIC_CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_<your-clerk-publishable-key>

# Convex backend env, not exposed to the browser.
# Do not add CLERK_JWT_ISSUER_DOMAIN to .env.local; set it only in Convex:
# bunx convex env set CLERK_JWT_ISSUER_DOMAIN https://<your-clerk-issuer-domain>
